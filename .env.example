# Free HuggingFace Inference API token (https://huggingface.co/settings/tokens)
# Optional: if unset or the API call fails, the app falls back to a
# rule-based template generator so it still works end-to-end.
HF_API_KEY=

# Optional: override the default HF text model
# HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Optional: override the default HF image-captioning model
# HF_IMAGE_MODEL=Salesforce/blip-image-captioning-base
